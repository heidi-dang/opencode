#!/usr/bin/env bash
set -euo pipefail
APP=opencode

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
OpenCode Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 1.0.180)
    -b, --binary <path>     Install from a local binary instead of downloading
        --local-repo        Install from current local repository (for development)
        --local-ui          Build and use local WebUI assets alongside local-repo
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Examples:
    curl -fsSL https://opencode.ai/install | bash
    curl -fsSL https://opencode.ai/install | bash -s -- --version 1.0.180
    ./install --binary /path/to/opencode
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""
local_repo=false
local_ui=false
health_lines=""
health_bun="pending"
health_node="pending"
health_lock="pending"
health_deps="pending"
health_ocode="pending"
health_webui="pending"
health_shell="pending"
health_wrapper="pending"
health_ui_dir="pending"
shell_config_file=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        --local-repo)
            local_repo=true
            shift
            ;;
        --local-ui)
            local_ui=true
            local_repo=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

INSTALL_DIR=$HOME/.opencode/bin
mkdir -p "$INSTALL_DIR"

# If --binary is provided, skip all download/detection logic
if [ -n "$binary_path" ]; then
    if [ ! -f "$binary_path" ]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi
    specific_version="local"
else
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="darwin" ;;
      Linux*) os="linux" ;;
      MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    esac

    arch=$(uname -m)
    if [[ "$arch" == "aarch64" ]]; then
      arch="arm64"
    fi
    if [[ "$arch" == "x86_64" ]]; then
      arch="x64"
    fi

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [ "$rosetta_flag" = "1" ]; then
        arch="arm64"
      fi
    fi

    combo="$os-$arch"
    case "$combo" in
      linux-x64|linux-arm64|darwin-x64|darwin-arm64|windows-x64)
        ;;
      *)
        echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}"
        exit 1
        ;;
    esac

    archive_ext=".zip"
    if [ "$os" = "linux" ]; then
      archive_ext=".tar.gz"
    fi

    is_musl=false
    if [ "$os" = "linux" ]; then
      if [ -f /etc/alpine-release ]; then
        is_musl=true
      fi

      if command -v ldd >/dev/null 2>&1; then
        if ldd --version 2>&1 | grep -qi musl; then
          is_musl=true
        fi
      fi
    fi

    needs_baseline=false
    if [ "$arch" = "x64" ]; then
      if [ "$os" = "linux" ]; then
        if ! grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "darwin" ]; then
        avx2=$(sysctl -n hw.optional.avx2_0 2>/dev/null || echo 0)
        if [ "$avx2" != "1" ]; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "windows" ]; then
        ps="(Add-Type -MemberDefinition \"[DllImport(\"\"kernel32.dll\"\")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);\" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)"
        out=""
        if command -v powershell.exe >/dev/null 2>&1; then
          out=$(powershell.exe -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        elif command -v pwsh >/dev/null 2>&1; then
          out=$(pwsh -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        fi
        out=$(echo "$out" | tr -d '\r' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
        if [ "$out" != "true" ] && [ "$out" != "1" ]; then
          needs_baseline=true
        fi
      fi
    fi

    target="$os-$arch"
    if [ "$needs_baseline" = "true" ]; then
      target="$target-baseline"
    fi
    if [ "$is_musl" = "true" ]; then
      target="$target-musl"
    fi

    filename="$APP-$target$archive_ext"


    if [ "$os" = "linux" ]; then
        if ! command -v tar >/dev/null 2>&1; then
             echo -e "${RED}Error: 'tar' is required but not installed.${NC}"
             exit 1
        fi
    else
        if ! command -v unzip >/dev/null 2>&1; then
            echo -e "${RED}Error: 'unzip' is required but not installed.${NC}"
            exit 1
        fi
    fi

    if [ -z "$requested_version" ]; then
        url="https://github.com/anomalyco/opencode/releases/latest/download/$filename"
        specific_version=$(curl -s https://api.github.com/repos/anomalyco/opencode/releases/latest | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ $? -ne 0 || -z "$specific_version" ]]; then
            echo -e "${RED}Failed to fetch version information${NC}"
            exit 1
        fi
    else
        # Strip leading 'v' if present
        requested_version="${requested_version#v}"
        url="https://github.com/anomalyco/opencode/releases/download/v${requested_version}/$filename"
        specific_version=$requested_version

        # Verify the release exists before downloading
        http_status=$(curl -sI -o /dev/null -w "%{http_code}" "https://github.com/anomalyco/opencode/releases/tag/v${requested_version}")
        if [ "$http_status" = "404" ]; then
            echo -e "${RED}Error: Release v${requested_version} not found${NC}"
            echo -e "${MUTED}Available releases: https://github.com/anomalyco/opencode/releases${NC}"
            exit 1
        fi
    fi
fi

print_message() {
    local level=$1
    local message=$2
    local color=""

    case $level in
        info) color="${NC}" ;;
        warning) color="${NC}" ;;
        error) color="${RED}" ;;
    esac

    echo -e "${color}${message}${NC}"
}

check_version() {
    if command -v opencode >/dev/null 2>&1; then
        opencode_path=$(which opencode)

        ## Check the installed version
        installed_version=$(opencode --version 2>/dev/null || echo "")

        if [[ "$installed_version" != "$specific_version" ]]; then
            print_message info "${MUTED}Installed version: ${NC}$installed_version."
        else
            print_message info "${MUTED}Version ${NC}$specific_version${MUTED} already installed"
            exit 0
        fi
    fi
}

health_add() {
    local state=$1
    local label=$2
    local detail=${3:-""}
    local icon=""
    case "$state" in
        pass) icon="✅" ;;
        warn) icon="⚠️" ;;
        fail) icon="❌" ;;
        *) icon="•" ;;
    esac
    if [ -n "$detail" ]; then
        health_lines="${health_lines}${icon} ${label}: ${detail}\n"
        return
    fi
    health_lines="${health_lines}${icon} ${label}\n"
}

print_health() {
    print_message info "\n${MUTED}Environment health report${NC}"
    printf "%b" "$health_lines"
    if [ "$health_bun" = "pass" ] && [ "$health_node" = "pass" ] && [ "$health_lock" = "pass" ] && [ "$health_deps" = "pass" ] && [ "$health_ocode" = "pass" ] && { [ "$local_ui" != "true" ] || [ "$health_webui" = "pass" ]; } && [ "$health_shell" = "pass" ] && [ "$health_wrapper" = "pass" ]; then
        print_message info "${MUTED}Status:${NC} Best supported environment verified for opencode${local_ui:+ and WebUI}."
        return
    fi
    print_message warning "${ORANGE}Status:${NC} Installed, but environment checks need attention."
}

ver_norm() {
    local v=${1#v}
    v=${v%%-*}
    v=${v%%+*}
    printf "%s" "$v"
}

ver_ge() {
    local a
    local b
    a=$(ver_norm "$1")
    b=$(ver_norm "$2")
    local a1 a2 a3 b1 b2 b3
    IFS='.' read -r a1 a2 a3 <<EOF
$a
EOF
    IFS='.' read -r b1 b2 b3 <<EOF
$b
EOF
    a1=${a1:-0}; a2=${a2:-0}; a3=${a3:-0}
    b1=${b1:-0}; b2=${b2:-0}; b3=${b3:-0}
    if [ "$a1" -gt "$b1" ]; then return 0; fi
    if [ "$a1" -lt "$b1" ]; then return 1; fi
    if [ "$a2" -gt "$b2" ]; then return 0; fi
    if [ "$a2" -lt "$b2" ]; then return 1; fi
    if [ "$a3" -ge "$b3" ]; then return 0; fi
    return 1
}

bun_expected() {
    local root=$1
    sed -n 's/.*"packageManager"[[:space:]]*:[[:space:]]*"bun@\([^"]*\)".*/\1/p' "$root/package.json" | head -1
}

catalog_version() {
    local root=$1
    local key=$2
    bun -e 'const f=JSON.parse(require("fs").readFileSync(process.argv[1], "utf8")); const k=process.argv[2]; console.log((f.workspaces&&f.workspaces.catalog&&f.workspaces.catalog[k])||"")' "$root/package.json" "$key" 2>/dev/null || true
}

require_lock() {
    local root=$1
    if [ -f "$root/bun.lock" ]; then
        health_lock="pass"
        health_add pass "Lockfile" "$root/bun.lock present"
        return 0
    fi
    health_lock="fail"
    health_add fail "Lockfile" "bun.lock is required for deterministic local install"
    print_message error "Missing bun.lock in $root"
    return 1
}

check_bun() {
    local root=$1
    if ! command -v bun >/dev/null 2>&1; then
        health_bun="fail"
        health_add fail "Bun" "bun is not installed"
        print_message error "bun is required. Install bun@$(bun_expected "$root") and retry."
        return 1
    fi
    local expect
    local got
    expect=$(bun_expected "$root")
    got=$(bun --version 2>/dev/null || true)
    if [ -z "$expect" ] || [ -z "$got" ]; then
        health_bun="fail"
        health_add fail "Bun" "Unable to verify bun version"
        print_message error "Unable to determine Bun version requirement"
        return 1
    fi
    local e_major g_major
    e_major=$(ver_norm "$expect" | cut -d. -f1)
    g_major=$(ver_norm "$got" | cut -d. -f1)
    if [ "$e_major" != "$g_major" ] || ! ver_ge "$got" "$expect"; then
        health_bun="fail"
        health_add fail "Bun" "Expected >=$expect (major $e_major), found $got"
        print_message error "Bun version mismatch. Required bun@$expect or compatible caret range. Found bun@$got"
        return 1
    fi
    health_bun="pass"
    health_add pass "Bun" "$got (expected >=$expect)"
    return 0
}

upgrade_node() {
    local dest="$HOME/.local/node"
    local arch
    arch=$(uname -m)
    case "$arch" in
        x86_64) arch="linux-x64" ;;
        aarch64|arm64) arch="linux-arm64" ;;
        *)
            print_message error "Unsupported architecture: $arch"
            return 1
            ;;
    esac

    print_message info "${MUTED}Fetching latest Node LTS from nodejs.org...${NC}"

    local version
    version=$(curl -sL "https://nodejs.org/dist/index.json" | \
        sed -n 's/.*"version":"v\([^"]*\)".*"lts":"\([^"]*\)".*/\1 \2/p' | \
        awk '$2 != "false" {print $1; exit}')
    if [ -z "$version" ]; then
        print_message error "Failed to fetch latest Node LTS version"
        return 1
    fi
    version=${version#v}

    print_message info "${MUTED}Upgrading Node to v$version...${NC}"

    mkdir -p "$dest"
    local url="https://nodejs.org/dist/v${version}/node-v${version}-${arch}.tar.xz"
    local tarball="/tmp/node-v${version}-${arch}.tar.xz"

    if ! curl -fSL --progress-bar "$url" -o "$tarball"; then
        print_message error "Failed to download Node v$version for $arch"
        return 1
    fi

    tar -xf "$tarball" -C "$dest" --strip-components=1
    rm -f "$tarball"

    # Add to shell config
    local node_bin="$dest/bin"
    local export_line="export PATH=\"\$HOME/.local/node/bin:\$PATH\""

    for cfg in "$HOME/.bashrc" "$HOME/.zshrc"; do
        if [ -f "$cfg" ]; then
            if ! grep -q "$node_bin" "$cfg" 2>/dev/null; then
                printf '\n%s\n' "$export_line" >> "$cfg"
            fi
        fi
    done

    # Re-export for this script session
    export PATH="$node_bin:$PATH"

    local new_node
    new_node=$("$node_bin/node" --version 2>/dev/null || true)
    if [ -z "$new_node" ]; then
        print_message error "Node upgrade verification failed"
        return 1
    fi

    print_message info "Node upgraded to $new_node at $node_bin"
    return 0
}

check_node() {
    if [ "$local_ui" != "true" ]; then
        health_node="pass"
        health_add pass "Node" "Not required (local-ui disabled)"
        return 0
    fi
    if ! command -v node >/dev/null 2>&1; then
        print_message warning "${ORANGE}Node not found — installing...${NC}"
        if ! upgrade_node; then
            health_node="fail"
            health_add fail "Node" "node is not installed"
            return 1
        fi
        health_node="pass"
        health_add pass "Node" "$(node --version) (installed)"
        return 0
    fi
    local got
    got=$(node --version 2>/dev/null || true)
    local major
    major=$(ver_norm "$got" | cut -d. -f1)
    if [ "$major" -gt "22" ]; then
        health_node="pass"
        health_add pass "Node" "$got"
        return 0
    fi
    if [ "$major" = "22" ] && ver_ge "$got" "22.12.0"; then
        health_node="pass"
        health_add pass "Node" "$got"
        return 0
    fi
    if [ "$major" = "20" ] && ver_ge "$got" "20.19.0"; then
        health_node="pass"
        health_add pass "Node" "$got"
        return 0
    fi

    # Too old — attempt auto-upgrade
    print_message warning "${ORANGE}Node $got is too old for Vite 7 — upgrading...${NC}"
    local old="$got"
    if ! upgrade_node; then
        health_node="fail"
        health_add fail "Node" "$got (upgrade failed)"
        print_message error "Node.js $got is unsupported. Please upgrade Node manually."
        return 1
    fi
    local new
    new=$(node --version)
    health_node="pass"
    health_add pass "Node" "$new (upgraded from $old)"
    return 0
}

clear_repo() {
    local root=$1
    print_message warning "${ORANGE}Repair:${NC} clearing repo dependency state"
    rm -rf "$root/node_modules" "$root/packages/opencode/node_modules" "$root/packages/app/node_modules" "$root/packages/ui/node_modules"
    rm -rf "$root/packages/opencode/dist" "$root/packages/app/dist"
}

clear_bun() {
    local dir
    dir=$(bun pm cache 2>/dev/null || true)
    if [ -n "$dir" ] && [ -d "$dir" ]; then
        print_message warning "${ORANGE}Repair:${NC} clearing Bun cache at $dir"
        rm -rf "$dir"
    fi
}

install_deps() {
    if [ "$os" = "windows" ]; then
        bun install --frozen-lockfile --linker hoisted
        return $?
    fi
    bun install --frozen-lockfile
}

check_deps() {
    local root=$1
    local dv
    local pv
    dv=$(catalog_version "$root" "drizzle-orm")
    pv=$(catalog_version "$root" "@pierre/diffs")

    # drizzle-orm: find anywhere in node_modules tree (workspace can hoist)
    local dp
    dp=$(find "$root/node_modules" -name "drizzle-orm" -type d 2>/dev/null | head -1)
    if [ -z "$dp" ]; then
        dp="$root/packages/opencode/node_modules/drizzle-orm"
    fi
    if [ ! -f "$dp/package.json" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "drizzle-orm package missing"
        return 1
    fi
    local got
    got=$(bun -e 'const f=JSON.parse(require("fs").readFileSync(process.argv[1], "utf8")); console.log(f.version||"")' "$dp/package.json" 2>/dev/null || true)
    if [ -n "$dv" ] && [ "$got" != "$dv" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "drizzle-orm version mismatch (expected $dv got $got)"
        return 1
    fi
    if [ ! -f "$dp/pg-core/primary-keys.js" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "drizzle-orm missing pg-core/primary-keys.js"
        return 1
    fi

    # @pierre/diffs: find package.json in .bun bundled cache or root node_modules
    # worker is at dist/worker/worker.js (exports map: ./worker/worker.js -> ./dist/worker/worker.js)
    local pj
    pj=$(find "$root/node_modules/.bun" -path "*/@pierre/diffs/package.json" 2>/dev/null | head -1)
    if [ -z "$pj" ]; then
        pj=$(find "$root/node_modules" -path "*/@pierre/diffs/package.json" 2>/dev/null | grep -v ".bun" | head -1)
    fi
    if [ -z "$pj" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "@pierre/diffs package not found"
        return 1
    fi
    local pdir
    pdir=$(dirname "$pj")
    if [ ! -f "$pdir/dist/worker/worker.js" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "@pierre/diffs dist/worker/worker.js missing"
        return 1
    fi
    health_deps="pass"
    health_add pass "Dependencies" "drizzle-orm@$got and @pierre/diffs@$pv integrity verified"
    return 0
}

shell_detect() {
    local p=""
    p=$(ps -p "$PPID" -o comm= 2>/dev/null | tr -d '[:space:]' || true)
    p=$(basename "$p")
    case "$p" in
        bash|zsh|fish|ash|sh) echo "$p"; return ;;
    esac
    basename "${SHELL:-sh}"
}

fail_local() {
    local msg=$1
    print_message error "$msg"
    if [ "$local_repo" = true ]; then
        print_health
    fi
    exit 1
}

unbuffered_sed() {
    if echo | sed -u -e "" >/dev/null 2>&1; then
        sed -nu "$@"
    elif echo | sed -l -e "" >/dev/null 2>&1; then
        sed -nl "$@"
    else
        local pad="$(printf "\n%512s" "")"
        sed -ne "s/$/\\${pad}/" "$@"
    fi
}

print_progress() {
    local bytes="$1"
    local length="$2"
    [ "$length" -gt 0 ] || return 0

    local width=50
    local percent=$(( bytes * 100 / length ))
    [ "$percent" -gt 100 ] && percent=100
    local on=$(( percent * width / 100 ))
    local off=$(( width - on ))

    local filled=$(printf "%*s" "$on" "")
    filled=${filled// /■}
    local empty=$(printf "%*s" "$off" "")
    empty=${empty// /･}

    printf "\r${ORANGE}%s%s %3d%%${NC}" "$filled" "$empty" "$percent" >&4
}

download_with_progress() {
    local url="$1"
    local output="$2"

    if [ -t 2 ]; then
        exec 4>&2
    else
        exec 4>/dev/null
    fi

    local tmp_dir=${TMPDIR:-/tmp}
    local basename="${tmp_dir}/opencode_install_$$"
    local tracefile="${basename}.trace"

    rm -f "$tracefile"
    mkfifo "$tracefile"

    # Hide cursor
    printf "\033[?25l" >&4

    trap "trap - RETURN; rm -f \"$tracefile\"; printf '\033[?25h' >&4; exec 4>&-" RETURN

    (
        curl --trace-ascii "$tracefile" -s -L -o "$output" "$url"
    ) &
    local curl_pid=$!

    unbuffered_sed \
        -e 'y/ACDEGHLNORTV/acdeghlnortv/' \
        -e '/^0000: content-length:/p' \
        -e '/^<= recv data/p' \
        "$tracefile" | \
    {
        local length=0
        local bytes=0

        while IFS=" " read -r -a line; do
            [ "${#line[@]}" -lt 2 ] && continue
            local tag="${line[0]} ${line[1]}"

            if [ "$tag" = "0000: content-length:" ]; then
                length="${line[2]}"
                length=$(echo "$length" | tr -d '\r')
                bytes=0
            elif [ "$tag" = "<= recv" ]; then
                local size="${line[3]}"
                bytes=$(( bytes + size ))
                if [ "$length" -gt 0 ]; then
                    print_progress "$bytes" "$length"
                fi
            fi
        done
    }

    wait $curl_pid
    local ret=$?
    echo "" >&4
    return $ret
}

download_and_install() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}version: ${NC}$specific_version"
    local tmp_dir="${TMPDIR:-/tmp}/opencode_install_$$"
    mkdir -p "$tmp_dir"

    if [[ "$os" == "windows" ]] || ! [ -t 2 ] || ! download_with_progress "$url" "$tmp_dir/$filename"; then
        # Fallback to standard curl on Windows, non-TTY environments, or if custom progress fails
        curl -# -L -o "$tmp_dir/$filename" "$url"
    fi

    if [ "$os" = "linux" ]; then
        tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
    else
        unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
    fi

    mv "$tmp_dir/opencode" "$INSTALL_DIR"
    chmod 755 "${INSTALL_DIR}/opencode"
    rm -rf "$tmp_dir"
}

install_from_binary() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}from: ${NC}$binary_path"
    cp "$binary_path" "${INSTALL_DIR}/opencode"
    chmod 755 "${INSTALL_DIR}/opencode"
    health_wrapper="pass"
    health_add pass "Wrapper" "${INSTALL_DIR}/opencode"
    health_bun="warn"
    health_node="warn"
    health_lock="warn"
    health_deps="warn"
    health_ocode="warn"
    health_webui="warn"
}

install_from_local_repo() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}from local repository...${NC}"
    
    # Check if we're in a git repository
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        print_message error "Not in a git repository"
        exit 1
    fi
    
    # Get repository root
    REPO_ROOT=$(git rev-parse --show-toplevel)
    print_message info "${MUTED}Repository root: ${NC}$REPO_ROOT"
    
    # Check if this looks like the opencode repository
    if [ ! -f "$REPO_ROOT/package.json" ]; then
        print_message error "No package.json found in repository root"
        exit 1
    fi
    
    # Check package.json name
    if ! grep -q '"name": "opencode"' "$REPO_ROOT/package.json"; then
        print_message error "This doesn't appear to be the opencode repository"
        exit 1
    fi
    
    print_message info "${MUTED}Building local version...${NC}"

    cd "$REPO_ROOT"
    require_lock "$REPO_ROOT" || fail_local "Missing required lockfile"
    check_bun "$REPO_ROOT" || fail_local "Bun environment check failed"
    check_node || fail_local "Node environment check failed"

    print_message info "${MUTED}Running deterministic bun install at root...${NC}"
    if ! install_deps; then
        print_message warning "${ORANGE}Install failed, running repair cycle...${NC}"
        clear_repo "$REPO_ROOT"
        clear_bun
        if ! install_deps; then
            health_deps="fail"
            health_add fail "Dependencies" "install failed even after repair"
            fail_local "Failed to run bun install after repair"
        fi
    fi

    if ! check_deps "$REPO_ROOT"; then
        print_message warning "${ORANGE}Dependency integrity failed, repairing...${NC}"
        clear_repo "$REPO_ROOT"
        clear_bun
        if ! install_deps || ! check_deps "$REPO_ROOT"; then
            fail_local "Dependency integrity checks failed after repair"
        fi
    fi

    if bun run --cwd packages/opencode build; then
        health_ocode="pass"
        health_add pass "OpenCode build" "packages/opencode build succeeded"
    else
        health_ocode="fail"
        health_add fail "OpenCode build" "packages/opencode build failed"
        fail_local "Failed to build the project"
    fi

    if [ "$local_ui" = true ]; then
        print_message info "${MUTED}Building WebUI assets...${NC}"
        if bun run --cwd packages/app build; then
            health_webui="pass"
            health_add pass "WebUI build" "packages/app build succeeded"
        else
            health_webui="fail"
            health_add fail "WebUI build" "packages/app build failed"
            fail_local "Failed to build WebUI assets"
        fi
        UI_PATH="$REPO_ROOT/packages/app/dist"
        if [ ! -d "$UI_PATH" ]; then
            health_webui="fail"
            health_add fail "WebUI output" "$UI_PATH not found"
            fail_local "WebUI build did not produce $UI_PATH"
        fi
        health_ui_dir="pass"
        health_add pass "WebUI output" "$UI_PATH"
    fi

    print_message info "${MUTED}Installing locally built version...${NC}"
    
    # Build the wrapper script with optional UI_DIR baked in
    local ui_export=""
    if [ "$local_ui" = true ] && [ -d "$REPO_ROOT/packages/app/dist" ]; then
        ui_export="export OPENCODE_UI_DIR=\"$REPO_ROOT/packages/app/dist\""
    fi

    # Create a wrapper script that calls local development version
    cat > "${INSTALL_DIR}/opencode" <<WRAPPER
#!/usr/bin/env bash
# OpenCode local development wrapper
REPO_ROOT="$REPO_ROOT"
$ui_export

# Check if we are in development mode
if [ -f "\$REPO_ROOT/packages/opencode/src/index.ts" ]; then
    cd "\$REPO_ROOT"
    exec bun run --cwd packages/opencode --conditions=browser src/index.ts "\$@"
else
    echo "Error: Development files not found"
    exit 1
fi
WRAPPER
    
    chmod 755 "${INSTALL_DIR}/opencode"
    health_wrapper="pass"
    health_add pass "Wrapper" "${INSTALL_DIR}/opencode"
    print_message info "${MUTED}Created development wrapper${NC}"
    
    specific_version="local"
    print_message info "${MUTED}Local install completed successfully!${NC}"
}

if [ "$local_repo" = true ]; then
    install_from_local_repo
elif [ -n "$binary_path" ]; then
    install_from_binary
else
    check_version
    download_and_install
fi


add_to_path() {
    local config_file=$1
    local command=$2

    if grep -Fxq "$command" "$config_file"; then
        print_message info "Command already exists in $config_file, skipping write."
    elif [[ -w $config_file ]]; then
        echo -e "\n# opencode" >> "$config_file"
        echo "$command" >> "$config_file"
        print_message info "${MUTED}Successfully added ${NC}opencode ${MUTED}to \$PATH in ${NC}$config_file"
    else
        print_message warning "Manually add the directory to $config_file (or similar):"
        print_message info "  $command"
    fi
}

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

current_shell=$(shell_detect)
case $current_shell in
    fish)
        config_files="$HOME/.config/fish/config.fish"
    ;;
    zsh)
        config_files="${ZDOTDIR:-$HOME}/.zshrc ${ZDOTDIR:-$HOME}/.zshenv $XDG_CONFIG_HOME/zsh/.zshrc $XDG_CONFIG_HOME/zsh/.zshenv"
    ;;
    bash)
        config_files="$HOME/.bashrc $HOME/.bash_profile $HOME/.profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
    ash)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    sh)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    *)
        # Default case if none of the above matches
        config_files="$HOME/.bashrc $HOME/.bash_profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
esac

if [[ "$no_modify_path" != "true" ]]; then
    config_file=""
    for file in $config_files; do
        if [[ -f $file ]]; then
            config_file=$file
            break
        fi
    done
    if [[ -z $config_file ]]; then
        health_shell="warn"
        health_add warn "Shell config" "No writable config found for $current_shell"
        print_message warning "No config file found for $current_shell. You may need to manually add to PATH:"
        print_message info "  export PATH=$INSTALL_DIR:\$PATH"
        shell_config_file="(manual)"
    elif [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
        case $current_shell in
            fish)
                add_to_path "$config_file" "fish_add_path $INSTALL_DIR"
            ;;
            zsh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            bash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            ash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            sh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            *)
                export PATH=$INSTALL_DIR:$PATH
                print_message warning "Manually add the directory to $config_file (or similar):"
                print_message info "  export PATH=$INSTALL_DIR:\$PATH"
            ;;
        esac
        shell_config_file="$config_file"
        health_shell="pass"
        health_add pass "Shell config" "$config_file"
    else
        shell_config_file="$config_file"
        health_shell="pass"
        health_add pass "Shell config" "$config_file"
    fi

    if [[ "$local_ui" = true ]]; then
        ui_path="$REPO_ROOT/packages/app/dist"
        if [[ -f $config_file ]]; then
            if ! grep -q "OPENCODE_UI_DIR" "$config_file"; then
                echo -e "\n# opencode local ui" >> "$config_file"
                echo "export OPENCODE_UI_DIR=\"$ui_path\"" >> "$config_file"
                print_message info "${MUTED}Added ${NC}OPENCODE_UI_DIR ${MUTED}to ${NC}$config_file"
                health_ui_dir="pass"
                health_add pass "OPENCODE_UI_DIR" "$config_file"
            else
                # Update existing
                sed -i "s|export OPENCODE_UI_DIR=.*|export OPENCODE_UI_DIR=\"$ui_path\"|" "$config_file"
                print_message info "${MUTED}Updated ${NC}OPENCODE_UI_DIR ${MUTED}in ${NC}$config_file"
                health_ui_dir="pass"
                health_add pass "OPENCODE_UI_DIR" "$config_file"
            fi
        else
            health_ui_dir="warn"
            health_add warn "OPENCODE_UI_DIR" "No shell config file to update automatically"
        fi
    fi
else
    health_shell="warn"
    health_add warn "Shell config" "Skipped due to --no-modify-path"
    if [ "$local_ui" = true ]; then
        health_ui_dir="warn"
        health_add warn "OPENCODE_UI_DIR" "Skipped due to --no-modify-path"
    fi
fi

if [ -n "${GITHUB_ACTIONS-}" ] && [ "${GITHUB_ACTIONS}" == "true" ]; then
    echo "$INSTALL_DIR" >> $GITHUB_PATH
    print_message info "Added $INSTALL_DIR to \$GITHUB_PATH"
fi

if [ "$local_repo" = true ]; then
    print_health
fi

echo -e ""
echo -e "${MUTED}                    ${NC}             ▄     "
echo -e "${MUTED}█▀▀█ █▀▀█ █▀▀█ █▀▀▄ ${NC}█▀▀▀ █▀▀█ █▀▀█ █▀▀█"
echo -e "${MUTED}█░░█ █░░█ █▀▀▀ █░░█ ${NC}█░░░ █░░█ █░░█ █▀▀▀"
echo -e "${MUTED}▀▀▀▀ █▀▀▀ ▀▀▀▀ ▀  ▀ ${NC}▀▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀▀▀▀"
echo -e ""
echo -e ""
echo -e "${MUTED}OpenCode includes free models, to start:${NC}"
echo -e ""
echo -e "cd <project>  ${MUTED}# Open directory${NC}"
echo -e "opencode      ${MUTED}# Run command${NC}"
echo -e ""
echo -e "${MUTED}For more information visit ${NC}https://opencode.ai/docs"
echo -e ""
echo -e ""
