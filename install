#!/usr/bin/env bash
set -euo pipefail
APP=opencode

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
OpenCode Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 1.0.180)
    -b, --binary <path>     Install from a local binary instead of downloading
        --local-repo        Install from current local repository (for development)
        --local-ui          Build and use local WebUI assets alongside local-repo
        --dry-run           Show planned changes without mutating anything
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Examples:
    curl -fsSL https://opencode.ai/install | bash
    curl -fsSL https://opencode.ai/install | bash -s -- --version 1.0.180
    ./install --binary /path/to/opencode
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""
local_repo=false
local_ui=false
dry_run=false
health_lines=""
health_bun="pending"
health_node="pending"
health_lock="pending"
health_deps="pending"
health_ocode="pending"
health_webui="pending"
health_shell="pending"
health_wrapper="pending"
health_ui_dir="pending"
shell_config_file=""
runtime_root=""
run_ts=""
run_dir=""
run_log=""
log_dir=""
health_json=""
snapshot_pre=""
snapshot_post=""
compare_json=""
lock_backup=""
pre_git_status=""
preferred_node_version=""
minimum_node_version=""
node_action="unchanged"
current_shell=""
repair_actions=""
compare_status="pending"
compare_summary=""
log_keep=10

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        --local-repo)
            local_repo=true
            shift
            ;;
        --local-ui)
            local_ui=true
            local_repo=true
            shift
            ;;
        --dry-run)
            dry_run=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

INSTALL_DIR=$HOME/.opencode/bin
mkdir -p "$INSTALL_DIR"
XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

runtime_root="$HOME/.opencode/install"
log_dir="$runtime_root/logs"
run_ts=$(date +%Y%m%d%H%M%S)
run_dir="$runtime_root/runs/$run_ts"
run_log="$log_dir/install-$run_ts.log"
health_json="$run_dir/install-health.json"
snapshot_pre="$run_dir/install-snapshot-pre.json"
snapshot_post="$run_dir/install-snapshot-post.json"
compare_json="$run_dir/install-compare.json"
mkdir -p "$INSTALL_DIR" "$log_dir" "$run_dir"
ln -sfn "$run_log" "$log_dir/latest.log"

if [ -z "${OPENCODE_INSTALL_LOGGING:-}" ]; then
    export OPENCODE_INSTALL_LOGGING=1
    exec > >(tee -a "$run_log") 2>&1
fi

# If --binary is provided, skip all download/detection logic
if [ -n "$binary_path" ]; then
    if [ ! -f "$binary_path" ]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi
    specific_version="local"
else
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="darwin" ;;
      Linux*) os="linux" ;;
      MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    esac

    arch=$(uname -m)
    if [[ "$arch" == "aarch64" ]]; then
      arch="arm64"
    fi
    if [[ "$arch" == "x86_64" ]]; then
      arch="x64"
    fi

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [ "$rosetta_flag" = "1" ]; then
        arch="arm64"
      fi
    fi

    combo="$os-$arch"
    case "$combo" in
      linux-x64|linux-arm64|darwin-x64|darwin-arm64|windows-x64)
        ;;
      *)
        echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}"
        exit 1
        ;;
    esac

    archive_ext=".zip"
    if [ "$os" = "linux" ]; then
      archive_ext=".tar.gz"
    fi

    is_musl=false
    if [ "$os" = "linux" ]; then
      if [ -f /etc/alpine-release ]; then
        is_musl=true
      fi

      if command -v ldd >/dev/null 2>&1; then
        if ldd --version 2>&1 | grep -qi musl; then
          is_musl=true
        fi
      fi
    fi

    needs_baseline=false
    if [ "$arch" = "x64" ]; then
      if [ "$os" = "linux" ]; then
        if ! grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "darwin" ]; then
        avx2=$(sysctl -n hw.optional.avx2_0 2>/dev/null || echo 0)
        if [ "$avx2" != "1" ]; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "windows" ]; then
        ps="(Add-Type -MemberDefinition \"[DllImport(\"\"kernel32.dll\"\")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);\" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)"
        out=""
        if command -v powershell.exe >/dev/null 2>&1; then
          out=$(powershell.exe -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        elif command -v pwsh >/dev/null 2>&1; then
          out=$(pwsh -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        fi
        out=$(echo "$out" | tr -d '\r' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
        if [ "$out" != "true" ] && [ "$out" != "1" ]; then
          needs_baseline=true
        fi
      fi
    fi

    target="$os-$arch"
    if [ "$needs_baseline" = "true" ]; then
      target="$target-baseline"
    fi
    if [ "$is_musl" = "true" ]; then
      target="$target-musl"
    fi

    filename="$APP-$target$archive_ext"


    if [ "$os" = "linux" ]; then
        if ! command -v tar >/dev/null 2>&1; then
             echo -e "${RED}Error: 'tar' is required but not installed.${NC}"
             exit 1
        fi
    else
        if ! command -v unzip >/dev/null 2>&1; then
            echo -e "${RED}Error: 'unzip' is required but not installed.${NC}"
            exit 1
        fi
    fi

    if [ -z "$requested_version" ]; then
        url="https://github.com/anomalyco/opencode/releases/latest/download/$filename"
        specific_version=$(curl -s https://api.github.com/repos/anomalyco/opencode/releases/latest | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ $? -ne 0 || -z "$specific_version" ]]; then
            echo -e "${RED}Failed to fetch version information${NC}"
            exit 1
        fi
    else
        # Strip leading 'v' if present
        requested_version="${requested_version#v}"
        url="https://github.com/anomalyco/opencode/releases/download/v${requested_version}/$filename"
        specific_version=$requested_version

        # Verify the release exists before downloading
        http_status=$(curl -sI -o /dev/null -w "%{http_code}" "https://github.com/anomalyco/opencode/releases/tag/v${requested_version}")
        if [ "$http_status" = "404" ]; then
            echo -e "${RED}Error: Release v${requested_version} not found${NC}"
            echo -e "${MUTED}Available releases: https://github.com/anomalyco/opencode/releases${NC}"
            exit 1
        fi
    fi
fi

print_message() {
    local level=$1
    local message=$2
    local color=""

    case $level in
        info) color="${NC}" ;;
        warning) color="${NC}" ;;
        error) color="${RED}" ;;
    esac

    echo -e "${color}${message}${NC}"
}

json_escape() {
    python3 - <<'PY' "$1"
import json, sys
print(json.dumps(sys.argv[1]))
PY
}

record_action() {
    local msg=$1
    if [ -n "$repair_actions" ]; then
        repair_actions="$repair_actions|$msg"
        return
    fi
    repair_actions="$msg"
}

trim_logs() {
    if [ ! -d "$log_dir" ]; then
        return
    fi
    python3 - <<'PY' "$log_dir" "$log_keep"
import os, sys
root = sys.argv[1]
keep = int(sys.argv[2])
files = sorted(
    [os.path.join(root, x) for x in os.listdir(root) if x.startswith("install-") and x.endswith(".log")],
    key=os.path.getmtime,
    reverse=True,
)
for path in files[keep:]:
    try:
        os.remove(path)
    except FileNotFoundError:
        pass
PY
}

trim_runs() {
    local runs="$runtime_root/runs"
    if [ ! -d "$runs" ]; then
        return
    fi
    python3 - <<'PY' "$runs" "$log_keep"
import os, shutil, sys
root = sys.argv[1]
keep = int(sys.argv[2])
dirs = sorted(
    [os.path.join(root, x) for x in os.listdir(root) if os.path.isdir(os.path.join(root, x))],
    key=os.path.getmtime,
    reverse=True,
)
for path in dirs[keep:]:
    shutil.rmtree(path, ignore_errors=True)
PY
}

runtime_finalize() {
    trim_logs
    trim_runs
}

preferred_node() {
    local root=$1
    python3 - <<'PY' "$root/package.json"
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as f:
    data = json.load(f)
print(data.get("opencode", {}).get("preferredNode", ""))
PY
}

minimum_node() {
    local root=$1
    python3 - <<'PY' "$root/package.json"
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as f:
    data = json.load(f)
print(data.get("opencode", {}).get("minimumNode", ""))
PY
}

hash_file() {
    local file=$1
    if [ ! -f "$file" ]; then
        printf ""
        return
    fi
    md5sum "$file" | cut -d' ' -f1
}

git_dirty() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        printf ""
        return
    fi
    git status --porcelain=v1
}

resolve_pkg() {
    local root=$1
    local spec=$2
    bun -e 'import { createRequire } from "node:module"; import fs from "node:fs"; const root = process.argv[1]; const spec = process.argv[2]; const req = createRequire(root + "/packages/opencode/package.json"); const file = req.resolve(spec + "/package.json"); const pkg = JSON.parse(fs.readFileSync(file, "utf8")); console.log(JSON.stringify({ version: pkg.version || "", file }))' "$root" "$spec" 2>/dev/null || true
}

shell_candidates() {
    case $1 in
        fish)
            printf "%s\n" "$HOME/.config/fish/config.fish"
            ;;
        zsh)
            printf "%s\n" "${ZDOTDIR:-$HOME}/.zshrc" "${ZDOTDIR:-$HOME}/.zshenv" "$XDG_CONFIG_HOME/zsh/.zshrc" "$XDG_CONFIG_HOME/zsh/.zshenv"
            ;;
        bash)
            printf "%s\n" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile" "$XDG_CONFIG_HOME/bash/.bashrc" "$XDG_CONFIG_HOME/bash/.bash_profile"
            ;;
        ash)
            printf "%s\n" "$HOME/.ashrc" "$HOME/.profile"
            ;;
        sh)
            printf "%s\n" "$HOME/.profile"
            ;;
        *)
            printf "%s\n" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"
            ;;
    esac
}

pick_shell_config() {
    local shell=$1
    local first=""
    while IFS= read -r file; do
        [ -z "$first" ] && first=$file
        if [ -f "$file" ]; then
            printf "%s" "$file"
            return
        fi
    done <<EOF
$(shell_candidates "$shell")
EOF
    printf "%s" "$first"
}

managed_block() {
    case $1 in
        fish)
            printf "# >>> opencode managed >>>\nfish_add_path %s\n# <<< opencode managed <<<\n" "$INSTALL_DIR"
            ;;
        *)
            printf "# >>> opencode managed >>>\nexport PATH=%s:\$PATH\n# <<< opencode managed <<<\n" "$INSTALL_DIR"
            ;;
    esac
}

managed_node_block() {
    case $1 in
        fish)
            printf "# >>> opencode node managed >>>\nfish_add_path %s\n# <<< opencode node managed <<<\n" "$HOME/.local/node/bin"
            ;;
        *)
            printf "# >>> opencode node managed >>>\nexport PATH=\"%s:\$PATH\"\n# <<< opencode node managed <<<\n" "$HOME/.local/node/bin"
            ;;
    esac
}

managed_ui_block() {
    local shell=$1
    local ui=$2
    case $shell in
        fish)
            printf "# >>> opencode ui managed >>>\nset -gx OPENCODE_UI_DIR %s\n# <<< opencode ui managed <<<\n" "$ui"
            ;;
        *)
            printf "# >>> opencode ui managed >>>\nexport OPENCODE_UI_DIR=\"%s\"\n# <<< opencode ui managed <<<\n" "$ui"
            ;;
    esac
}

write_block() {
    local file=$1
    local marker=$2
    local body=$3
    [ -z "$file" ] && return 1
    if [ "$dry_run" = true ]; then
        print_message info "${MUTED}[dry-run] would update ${NC}$file${MUTED} block ${NC}$marker"
        return 0
    fi
    python3 - <<'PY' "$file" "$marker" "$body"
import pathlib, sys
path = pathlib.Path(sys.argv[1])
marker = sys.argv[2]
body = sys.argv[3]
start = f"# >>> {marker} >>>"
end = f"# <<< {marker} <<<"
text = path.read_text(encoding="utf-8") if path.exists() else ""
lines = text.splitlines()
out = []
i = 0
while i < len(lines):
    if lines[i].strip() == start:
        i += 1
        while i < len(lines) and lines[i].strip() != end:
            i += 1
        if i < len(lines):
            i += 1
        continue
    out.append(lines[i])
    i += 1
if out and out[-1] != "":
    out.append("")
out.extend(body.strip("\n").splitlines())
out.append("")
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text("\n".join(out), encoding="utf-8")
PY
}

capture_snapshot() {
    local out=$1
    local root=${2:-$PWD}
    local shell_cfg=$3
    local dr=$(resolve_pkg "$root" "drizzle-orm")
    local pd=$(resolve_pkg "$root" "@pierre/diffs")
    local dirty=""
    local branch=""
    local commit=""
    if git -C "$root" rev-parse --git-dir >/dev/null 2>&1; then
        dirty=$(git -C "$root" status --porcelain=v1)
        branch=$(git -C "$root" rev-parse --abbrev-ref HEAD)
        commit=$(git -C "$root" rev-parse HEAD)
    fi
    python3 - <<'PY' "$out" "$root" "$run_ts" "$current_shell" "$shell_cfg" "$INSTALL_DIR" "$run_log" "$health_json" "$snapshot_pre" "$snapshot_post" "$compare_json" "$dr" "$pd" "$preferred_node_version" "$minimum_node_version" "$node_action" "$local_repo" "$local_ui" "$dry_run" "$no_modify_path" "$repair_actions" "$branch" "$commit" "$dirty"
import json, os, pathlib, subprocess, sys
out, root, ts, shell_name, shell_cfg, install_dir, run_log, health_json, pre_path, post_path, compare_json, dr, pd, preferred, minimum, node_action, local_repo, local_ui, dry_run, no_modify_path, repair, branch, commit, dirty = sys.argv[1:25]
def sh(cmd):
    try:
        return subprocess.check_output(cmd, text=True).strip()
    except Exception:
        return ""
def md5(path):
    p = pathlib.Path(path)
    if not p.exists() or not p.is_file():
        return ""
    import hashlib
    return hashlib.md5(p.read_bytes()).hexdigest()
def parse_pkg(raw):
    if not raw:
        return {"version": "", "file": ""}
    try:
        return json.loads(raw)
    except Exception:
        return {"version": "", "file": ""}
data = {
    "timestamp": ts,
    "machine": {
        "uname": sh(["uname", "-a"]),
        "os": sh(["uname", "-s"]),
        "arch": sh(["uname", "-m"]),
    },
    "tools": {
        "bun": {"path": sh(["bash", "-lc", "command -v bun || true"]), "version": sh(["bash", "-lc", "bun --version 2>/dev/null || true"])},
        "node": {"path": sh(["bash", "-lc", "command -v node || true"]), "version": sh(["bash", "-lc", "node --version 2>/dev/null || true"]), "preferred": preferred, "minimum": minimum, "action": node_action},
        "python3": {"path": sh(["bash", "-lc", "command -v python3 || true"]), "version": sh(["bash", "-lc", "python3 --version 2>/dev/null || true"])},
        "git": {"path": sh(["bash", "-lc", "command -v git || true"]), "version": sh(["bash", "-lc", "git --version 2>/dev/null || true"])},
    },
    "repo": {
        "root": root,
        "branch": branch,
        "commit": commit,
        "dirty": dirty.splitlines() if dirty else [],
        "hashes": {
            "bun.lock": md5(os.path.join(root, "bun.lock")),
            "package.json": md5(os.path.join(root, "package.json")),
            "packages/opencode/package.json": md5(os.path.join(root, "packages/opencode/package.json")),
            "packages/app/package.json": md5(os.path.join(root, "packages/app/package.json")),
        },
    },
    "deps": {
        "drizzle": parse_pkg(dr),
        "pierre": parse_pkg(pd),
        "pierre_worker": os.path.join(parse_pkg(pd).get("file", "").rsplit("/package.json", 1)[0], "dist/worker/worker.js") if parse_pkg(pd).get("file") else "",
    },
    "shell": {
        "name": shell_name,
        "config": shell_cfg,
        "path_contains_install": install_dir in os.environ.get("PATH", "").split(":") if os.environ.get("PATH") else False,
        "opencode_ui_dir": os.environ.get("OPENCODE_UI_DIR", ""),
    },
    "artifacts": {
        "install_dir": install_dir,
        "wrapper": sh(["bash", "-lc", "command -v opencode || true"]),
        "log": run_log,
        "health_json": health_json,
        "snapshot_pre": pre_path,
        "snapshot_post": post_path,
        "compare_json": compare_json,
    },
    "run": {
        "local_repo": local_repo == "true",
        "local_ui": local_ui == "true",
        "dry_run": dry_run == "true",
        "no_modify_path": no_modify_path == "true",
        "repair_actions": repair.split("|") if repair else [],
    },
}
pathlib.Path(out).parent.mkdir(parents=True, exist_ok=True)
pathlib.Path(out).write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
PY
}

write_health_json() {
    python3 - <<'PY' "$health_json" "$run_ts" "$run_log" "$snapshot_pre" "$snapshot_post" "$compare_json" "$health_lines" "$health_bun" "$health_node" "$health_lock" "$health_deps" "$health_ocode" "$health_webui" "$health_shell" "$health_wrapper" "$health_ui_dir" "$compare_status" "$compare_summary" "$dry_run" "$repair_actions"
import json, pathlib, sys
path, ts, log, pre, post, compare, lines, bun, node, lock, deps, ocode, webui, shell, wrapper, ui, compare_status, compare_summary, dry_run, repair = sys.argv[1:21]
data = {
    "timestamp": ts,
    "dry_run": dry_run == "true",
    "checks": {
        "bun": bun,
        "node": node,
        "lock": lock,
        "deps": deps,
        "opencode_build": ocode,
        "webui_build": webui,
        "shell": shell,
        "wrapper": wrapper,
        "ui_dir": ui,
    },
    "health_lines": [line for line in lines.split("\\n") if line],
    "artifacts": {
        "log": log,
        "snapshot_pre": pre,
        "snapshot_post": post,
        "compare": compare,
    },
    "compare": {
        "status": compare_status,
        "summary": compare_summary,
    },
    "actions": repair.split("|") if repair else [],
}
pathlib.Path(path).write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
PY
}

compare_snapshots() {
    python3 - <<'PY' "$snapshot_pre" "$snapshot_post" "$compare_json"
import json, pathlib, sys
pre = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
post = json.loads(pathlib.Path(sys.argv[2]).read_text(encoding="utf-8"))
out = pathlib.Path(sys.argv[3])
changes = []
status = "pass"
def note(kind, field, before, after, level):
    global status
    changes.append({"kind": kind, "field": field, "before": before, "after": after, "level": level})
    if level == "regression":
        status = "fail"
    elif level == "warning" and status == "pass":
        status = "warn"
if pre["machine"] != post["machine"]:
    note("machine", "machine", pre["machine"], post["machine"], "regression")
if pre["repo"]["branch"] != post["repo"]["branch"]:
    note("repo", "branch", pre["repo"]["branch"], post["repo"]["branch"], "regression")
if pre["repo"]["commit"] != post["repo"]["commit"]:
    note("repo", "commit", pre["repo"]["commit"], post["repo"]["commit"], "regression")
if pre["repo"]["dirty"] != post["repo"]["dirty"]:
    note("repo", "dirty", pre["repo"]["dirty"], post["repo"]["dirty"], "regression")
for key, value in pre["repo"]["hashes"].items():
    after = post["repo"]["hashes"].get(key)
    if value != after:
        note("repo", key, value, after, "regression")
if pre["deps"]["drizzle"]["version"] != post["deps"]["drizzle"]["version"]:
    note("deps", "drizzle.version", pre["deps"]["drizzle"]["version"], post["deps"]["drizzle"]["version"], "regression")
if pre["deps"]["pierre"]["version"] != post["deps"]["pierre"]["version"]:
    note("deps", "pierre.version", pre["deps"]["pierre"]["version"], post["deps"]["pierre"]["version"], "regression")
if pre["tools"]["bun"]["version"] != post["tools"]["bun"]["version"]:
    note("tools", "bun.version", pre["tools"]["bun"]["version"], post["tools"]["bun"]["version"], "regression")
if pre["tools"]["node"]["preferred"] and post["tools"]["node"]["version"] != pre["tools"]["node"]["preferred"]:
    note("tools", "node.version", pre["tools"]["node"]["preferred"], post["tools"]["node"]["version"], "warning")
summary = "No unexpected drift"
if changes:
    summary = f"{len(changes)} compared changes"
data = {"status": status, "summary": summary, "changes": changes}
out.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
print(status)
print(summary)
PY
}

run_cmd() {
    if [ "$dry_run" = true ]; then
        print_message info "${MUTED}[dry-run] would run:${NC} $*"
        return 0
    fi
    "$@"
}

check_version() {
    if command -v opencode >/dev/null 2>&1; then
        opencode_path=$(which opencode)

        ## Check the installed version
        installed_version=$(opencode --version 2>/dev/null || echo "")

        if [[ "$installed_version" != "$specific_version" ]]; then
            print_message info "${MUTED}Installed version: ${NC}$installed_version."
        else
            print_message info "${MUTED}Version ${NC}$specific_version${MUTED} already installed"
            exit 0
        fi
    fi
}

health_add() {
    local state=$1
    local label=$2
    local detail=${3:-""}
    local icon=""
    case "$state" in
        pass) icon="✅" ;;
        warn) icon="⚠️" ;;
        fail) icon="❌" ;;
        *) icon="•" ;;
    esac
    if [ -n "$detail" ]; then
        health_lines="${health_lines}${icon} ${label}: ${detail}\n"
        return
    fi
    health_lines="${health_lines}${icon} ${label}\n"
}

print_health() {
    print_message info "\n${MUTED}Environment health report${NC}"
    printf "%b" "$health_lines"
    if [ "$health_bun" = "pass" ] && [ "$health_node" = "pass" ] && [ "$health_lock" = "pass" ] && [ "$health_deps" = "pass" ] && [ "$health_ocode" = "pass" ] && { [ "$local_ui" != "true" ] || [ "$health_webui" = "pass" ]; } && [ "$health_shell" = "pass" ] && [ "$health_wrapper" = "pass" ]; then
        print_message info "${MUTED}Status:${NC} Best supported environment verified for opencode${local_ui:+ and WebUI}."
        return
    fi
    print_message warning "${ORANGE}Status:${NC} Installed, but environment checks need attention."
}

ver_norm() {
    local v=${1#v}
    v=${v%%-*}
    v=${v%%+*}
    printf "%s" "$v"
}

ver_ge() {
    local a
    local b
    a=$(ver_norm "$1")
    b=$(ver_norm "$2")
    local a1 a2 a3 b1 b2 b3
    IFS='.' read -r a1 a2 a3 <<EOF
$a
EOF
    IFS='.' read -r b1 b2 b3 <<EOF
$b
EOF
    a1=${a1:-0}; a2=${a2:-0}; a3=${a3:-0}
    b1=${b1:-0}; b2=${b2:-0}; b3=${b3:-0}
    if [ "$a1" -gt "$b1" ]; then return 0; fi
    if [ "$a1" -lt "$b1" ]; then return 1; fi
    if [ "$a2" -gt "$b2" ]; then return 0; fi
    if [ "$a2" -lt "$b2" ]; then return 1; fi
    if [ "$a3" -ge "$b3" ]; then return 0; fi
    return 1
}

bun_expected() {
    local root=$1
    sed -n 's/.*"packageManager"[[:space:]]*:[[:space:]]*"bun@\([^"]*\)".*/\1/p' "$root/package.json" | head -1
}

catalog_version() {
    local root=$1
    local key=$2
    bun -e 'const f=JSON.parse(require("fs").readFileSync(process.argv[1], "utf8")); const k=process.argv[2]; console.log((f.workspaces&&f.workspaces.catalog&&f.workspaces.catalog[k])||"")' "$root/package.json" "$key" 2>/dev/null || true
}

require_lock() {
    local root=$1
    if [ -f "$root/bun.lock" ]; then
        health_lock="pass"
        health_add pass "Lockfile" "$root/bun.lock present"
        return 0
    fi
    health_lock="fail"
    health_add fail "Lockfile" "bun.lock is required for deterministic local install"
    print_message error "Missing bun.lock in $root"
    return 1
}

check_bun() {
    local root=$1
    if ! command -v bun >/dev/null 2>&1; then
        health_bun="fail"
        health_add fail "Bun" "bun is not installed"
        print_message error "bun is required. Install bun@$(bun_expected "$root") and retry."
        return 1
    fi
    local expect
    local got
    expect=$(bun_expected "$root")
    got=$(bun --version 2>/dev/null || true)
    if [ -z "$expect" ] || [ -z "$got" ]; then
        health_bun="fail"
        health_add fail "Bun" "Unable to verify bun version"
        print_message error "Unable to determine Bun version requirement"
        return 1
    fi
    local e_major g_major
    e_major=$(ver_norm "$expect" | cut -d. -f1)
    g_major=$(ver_norm "$got" | cut -d. -f1)
    if [ "$e_major" != "$g_major" ] || ! ver_ge "$got" "$expect"; then
        health_bun="fail"
        health_add fail "Bun" "Expected >=$expect (major $e_major), found $got"
        print_message error "Bun version mismatch. Required bun@$expect or compatible caret range. Found bun@$got"
        return 1
    fi
    health_bun="pass"
    health_add pass "Bun" "$got (expected >=$expect)"
    return 0
}

upgrade_node() {
    local dest="$HOME/.local/node"
    local arch
    arch=$(uname -m)
    case "$arch" in
        x86_64) arch="linux-x64" ;;
        aarch64|arm64) arch="linux-arm64" ;;
        *)
            print_message error "Unsupported architecture: $arch"
            return 1
            ;;
    esac

    print_message info "${MUTED}Preparing preferred Node runtime...${NC}"

    local version="$preferred_node_version"
    if [ -z "$version" ]; then
        version=$(curl -sL "https://nodejs.org/dist/index.json" | \
            sed -n 's/.*"version":"v\([^"]*\)".*"lts":"\([^"]*\)".*/\1 \2/p' | \
            awk '$2 != "false" {print $1; exit}')
    fi
    if [ -z "$version" ]; then
        print_message error "Failed to determine preferred Node version"
        return 1
    fi
    version=${version#v}

    print_message info "${MUTED}Upgrading Node to v$version...${NC}"
    record_action "node-upgrade:v$version"

    if [ "$dry_run" = true ]; then
        node_action="would-upgrade"
        return 0
    fi

    mkdir -p "$dest"
    local url="https://nodejs.org/dist/v${version}/node-v${version}-${arch}.tar.xz"
    local tarball="/tmp/node-v${version}-${arch}.tar.xz"

    if ! curl -fSL --progress-bar "$url" -o "$tarball"; then
        print_message error "Failed to download Node v$version for $arch"
        return 1
    fi

    tar -xf "$tarball" -C "$dest" --strip-components=1
    rm -f "$tarball"

    # Add to shell config
    local node_bin="$dest/bin"
    local cfg
    while IFS= read -r cfg; do
        [ -z "$cfg" ] && continue
        write_block "$cfg" "opencode node managed" "$(managed_node_block "$current_shell")"
        break
    done <<EOF
$(shell_candidates "$current_shell")
EOF

    # Re-export for this script session
    export PATH="$node_bin:$PATH"

    local new_node
    new_node=$("$node_bin/node" --version 2>/dev/null || true)
    if [ -z "$new_node" ]; then
        print_message error "Node upgrade verification failed"
        return 1
    fi

    print_message info "Node upgraded to $new_node at $node_bin"
    node_action="upgraded"
    return 0
}

check_node() {
    if [ "$local_ui" != "true" ]; then
        health_node="pass"
        health_add pass "Node" "Not required (local-ui disabled)"
        return 0
    fi
    if ! command -v node >/dev/null 2>&1; then
        print_message warning "${ORANGE}Node not found — installing...${NC}"
        if ! upgrade_node; then
            health_node="fail"
            health_add fail "Node" "node is not installed"
            return 1
        fi
        health_node="pass"
        health_add pass "Node" "$(node --version) (installed)"
        return 0
    fi
    local got
    got=$(node --version 2>/dev/null || true)
    local major
    major=$(ver_norm "$got" | cut -d. -f1)
    if [ -n "$preferred_node_version" ] && [ "$got" = "$preferred_node_version" ]; then
        health_node="pass"
        health_add pass "Node" "$got (preferred)"
        return 0
    fi
    if [ "$major" -gt "22" ]; then
        health_node="pass"
        health_add pass "Node" "$got"
        return 0
    fi
    if [ -n "$minimum_node_version" ] && ver_ge "$got" "$minimum_node_version"; then
        health_node="pass"
        health_add pass "Node" "$got"
        return 0
    fi

    # Too old — attempt auto-upgrade
    print_message warning "${ORANGE}Node $got is too old for Vite 7 — upgrading...${NC}"
    local old="$got"
    if ! upgrade_node; then
        health_node="fail"
        health_add fail "Node" "$got (upgrade failed)"
        print_message error "Node.js $got is unsupported. Please upgrade Node manually."
        return 1
    fi
    local new
    new=$(node --version)
    health_node="pass"
    health_add pass "Node" "$new (upgraded from $old)"
    return 0
}

clear_repo() {
    local root=$1
    print_message warning "${ORANGE}Repair:${NC} clearing repo dependency state"
    rm -rf "$root/node_modules" "$root/packages/opencode/node_modules" "$root/packages/app/node_modules" "$root/packages/ui/node_modules"
    rm -rf "$root/packages/opencode/dist" "$root/packages/app/dist"
}

clear_bun() {
    local dir
    dir=$(bun pm cache 2>/dev/null || true)
    if [ -n "$dir" ] && [ -d "$dir" ]; then
        print_message warning "${ORANGE}Repair:${NC} clearing Bun cache at $dir"
        rm -rf "$dir"
    fi
}

install_deps() {
    record_action "bun-install-frozen"
    if [ "$dry_run" = true ]; then
        print_message info "${MUTED}[dry-run] would verify and install dependencies from bun.lock${NC}"
        return 0
    fi
    if [ "$os" = "windows" ]; then
        bun install --frozen-lockfile --linker hoisted
        return $?
    fi
    bun install --frozen-lockfile
}

check_deps() {
    local root=$1
    local dv
    local pv
    dv=$(catalog_version "$root" "drizzle-orm")
    pv=$(catalog_version "$root" "@pierre/diffs")

    local dr pj got pdir
    dr=$(resolve_pkg "$root" "drizzle-orm")
    pj=$(python3 - <<'PY' "$dr"
import json, sys
raw = sys.argv[1]
if not raw:
    print("")
else:
    print(json.loads(raw).get("file", ""))
PY
)
    if [ -z "$pj" ] || [ ! -f "$pj" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "drizzle-orm package missing"
        return 1
    fi
    got=$(bun -e 'const f=JSON.parse(require("fs").readFileSync(process.argv[1], "utf8")); console.log(f.version||"")' "$pj" 2>/dev/null || true)
    if [ -n "$dv" ] && [ "$got" != "$dv" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "drizzle-orm version mismatch (expected $dv got $got)"
        return 1
    fi

    dr=$(resolve_pkg "$root" "@pierre/diffs")
    pj=$(python3 - <<'PY' "$dr"
import json, sys
raw = sys.argv[1]
if not raw:
    print("")
else:
    print(json.loads(raw).get("file", ""))
PY
)
    if [ -z "$pj" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "@pierre/diffs package not found"
        return 1
    fi
    pdir=$(dirname "$pj")
    if [ ! -f "$pdir/dist/worker/worker.js" ]; then
        health_deps="fail"
        health_add fail "Dependencies" "@pierre/diffs dist/worker/worker.js missing"
        return 1
    fi
    health_deps="pass"
    health_add pass "Dependencies" "drizzle-orm@$got and @pierre/diffs@$pv integrity verified"
    return 0
}

shell_detect() {
    local p=""
    p=$(ps -p "$PPID" -o comm= 2>/dev/null | tr -d '[:space:]' || true)
    p=$(basename "$p")
    case "$p" in
        bash|zsh|fish|ash|sh) echo "$p"; return ;;
    esac
    basename "${SHELL:-sh}"
}

fail_local() {
    local msg=$1
    print_message error "$msg"
    if [ "$local_repo" = true ]; then
        if [ -n "${REPO_ROOT:-}" ] && [ -f "$snapshot_pre" ]; then
            capture_snapshot "$snapshot_post" "$REPO_ROOT" "$shell_config_file"
            local cmp_result
            cmp_result=$(compare_snapshots)
            compare_status=$(printf "%s" "$cmp_result" | sed -n '1p')
            compare_summary=$(printf "%s" "$cmp_result" | sed -n '2p')
        fi
        write_health_json
        print_health
    fi
    runtime_finalize
    exit 1
}

unbuffered_sed() {
    if echo | sed -u -e "" >/dev/null 2>&1; then
        sed -nu "$@"
    elif echo | sed -l -e "" >/dev/null 2>&1; then
        sed -nl "$@"
    else
        local pad="$(printf "\n%512s" "")"
        sed -ne "s/$/\\${pad}/" "$@"
    fi
}

print_progress() {
    local bytes="$1"
    local length="$2"
    [ "$length" -gt 0 ] || return 0

    local width=50
    local percent=$(( bytes * 100 / length ))
    [ "$percent" -gt 100 ] && percent=100
    local on=$(( percent * width / 100 ))
    local off=$(( width - on ))

    local filled=$(printf "%*s" "$on" "")
    filled=${filled// /■}
    local empty=$(printf "%*s" "$off" "")
    empty=${empty// /･}

    printf "\r${ORANGE}%s%s %3d%%${NC}" "$filled" "$empty" "$percent" >&4
}

download_with_progress() {
    local url="$1"
    local output="$2"

    if [ -t 2 ]; then
        exec 4>&2
    else
        exec 4>/dev/null
    fi

    local tmp_dir=${TMPDIR:-/tmp}
    local basename="${tmp_dir}/opencode_install_$$"
    local tracefile="${basename}.trace"

    rm -f "$tracefile"
    mkfifo "$tracefile"

    # Hide cursor
    printf "\033[?25l" >&4

    trap "trap - RETURN; rm -f \"$tracefile\"; printf '\033[?25h' >&4; exec 4>&-" RETURN

    (
        curl --trace-ascii "$tracefile" -s -L -o "$output" "$url"
    ) &
    local curl_pid=$!

    unbuffered_sed \
        -e 'y/ACDEGHLNORTV/acdeghlnortv/' \
        -e '/^0000: content-length:/p' \
        -e '/^<= recv data/p' \
        "$tracefile" | \
    {
        local length=0
        local bytes=0

        while IFS=" " read -r -a line; do
            [ "${#line[@]}" -lt 2 ] && continue
            local tag="${line[0]} ${line[1]}"

            if [ "$tag" = "0000: content-length:" ]; then
                length="${line[2]}"
                length=$(echo "$length" | tr -d '\r')
                bytes=0
            elif [ "$tag" = "<= recv" ]; then
                local size="${line[3]}"
                bytes=$(( bytes + size ))
                if [ "$length" -gt 0 ]; then
                    print_progress "$bytes" "$length"
                fi
            fi
        done
    }

    wait $curl_pid
    local ret=$?
    echo "" >&4
    return $ret
}

download_and_install() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}version: ${NC}$specific_version"
    local tmp_dir="${TMPDIR:-/tmp}/opencode_install_$$"
    mkdir -p "$tmp_dir"

    if [[ "$os" == "windows" ]] || ! [ -t 2 ] || ! download_with_progress "$url" "$tmp_dir/$filename"; then
        # Fallback to standard curl on Windows, non-TTY environments, or if custom progress fails
        curl -# -L -o "$tmp_dir/$filename" "$url"
    fi

    if [ "$os" = "linux" ]; then
        tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
    else
        unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
    fi

    mv "$tmp_dir/opencode" "$INSTALL_DIR"
    chmod 755 "${INSTALL_DIR}/opencode"
    rm -rf "$tmp_dir"
}

install_from_binary() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}from: ${NC}$binary_path"
    cp "$binary_path" "${INSTALL_DIR}/opencode"
    chmod 755 "${INSTALL_DIR}/opencode"
    health_wrapper="pass"
    health_add pass "Wrapper" "${INSTALL_DIR}/opencode"
    health_bun="warn"
    health_node="warn"
    health_lock="warn"
    health_deps="warn"
    health_ocode="warn"
    health_webui="warn"
    compare_status="warn"
    compare_summary="Binary installs do not use local repo comparison"
}

install_from_local_repo() {
    print_message info "\n${MUTED}Installing ${NC}opencode ${MUTED}from local repository...${NC}"
    
    # Check if we're in a git repository
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        print_message error "Not in a git repository"
        exit 1
    fi
    
    # Get repository root
    REPO_ROOT=$(git rev-parse --show-toplevel)
    print_message info "${MUTED}Repository root: ${NC}$REPO_ROOT"
    
    # Check if this looks like the opencode repository
    if [ ! -f "$REPO_ROOT/package.json" ]; then
        print_message error "No package.json found in repository root"
        exit 1
    fi
    
    # Check package.json name
    if ! grep -q '"name": "opencode"' "$REPO_ROOT/package.json"; then
        print_message error "This doesn't appear to be the opencode repository"
        exit 1
    fi
    
    print_message info "${MUTED}Building local version...${NC}"

    cd "$REPO_ROOT"
    preferred_node_version=$(preferred_node "$REPO_ROOT")
    minimum_node_version=$(minimum_node "$REPO_ROOT")
    current_shell=$(shell_detect)
    shell_config_file=$(pick_shell_config "$current_shell")
    pre_git_status=$(git_dirty)
    if [ -n "$pre_git_status" ]; then
        health_add warn "Dirty repo" "Pre-existing tracked changes detected before install"
    fi
    capture_snapshot "$snapshot_pre" "$REPO_ROOT" "$shell_config_file"
    require_lock "$REPO_ROOT" || fail_local "Missing required lockfile"
    check_bun "$REPO_ROOT" || fail_local "Bun environment check failed"
    check_node || fail_local "Node environment check failed"

    lock_backup="$run_dir/bun.lock.before"
    cp "$REPO_ROOT/bun.lock" "$lock_backup"

    print_message info "${MUTED}Running deterministic bun install at root...${NC}"
    if ! install_deps; then
        print_message warning "${ORANGE}Install failed, running repair cycle...${NC}"
        clear_repo "$REPO_ROOT"
        clear_bun
        if ! install_deps; then
            health_deps="fail"
            health_add fail "Dependencies" "install failed even after repair"
            fail_local "Failed to run bun install after repair"
        fi
    fi

    if ! check_deps "$REPO_ROOT"; then
        print_message warning "${ORANGE}Dependency integrity failed, repairing...${NC}"
        clear_repo "$REPO_ROOT"
        clear_bun
        if ! install_deps || ! check_deps "$REPO_ROOT"; then
            fail_local "Dependency integrity checks failed after repair"
        fi
    fi

    if [ "$dry_run" = true ]; then
        health_ocode="warn"
        health_add warn "OpenCode build" "Skipped due to --dry-run"
    elif bun run --cwd packages/opencode build -- --skip-install; then
        health_ocode="pass"
        health_add pass "OpenCode build" "packages/opencode build succeeded"
    else
        health_ocode="fail"
        health_add fail "OpenCode build" "packages/opencode build failed"
        fail_local "Failed to build the project"
    fi

    if [ "$local_ui" = true ] && [ "$dry_run" = true ]; then
        health_webui="warn"
        health_add warn "WebUI build" "Skipped due to --dry-run"
        health_ui_dir="warn"
        health_add warn "WebUI output" "Skipped due to --dry-run"
    elif [ "$local_ui" = true ]; then
        print_message info "${MUTED}Building WebUI assets...${NC}"
        if bun run --cwd packages/app build; then
            health_webui="pass"
            health_add pass "WebUI build" "packages/app build succeeded"
        else
            health_webui="fail"
            health_add fail "WebUI build" "packages/app build failed"
            fail_local "Failed to build WebUI assets"
        fi
        UI_PATH="$REPO_ROOT/packages/app/dist"
        if [ ! -d "$UI_PATH" ]; then
            health_webui="fail"
            health_add fail "WebUI output" "$UI_PATH not found"
            fail_local "WebUI build did not produce $UI_PATH"
        fi
        health_ui_dir="pass"
        health_add pass "WebUI output" "$UI_PATH"
    fi

    print_message info "${MUTED}Installing locally built version...${NC}"
    
    # Build the wrapper script with optional UI_DIR baked in
    local ui_export=""
    if [ "$local_ui" = true ] && [ -d "$REPO_ROOT/packages/app/dist" ]; then
        ui_export="export OPENCODE_UI_DIR=\"$REPO_ROOT/packages/app/dist\""
    fi

    # Create a wrapper script that calls local development version
    if [ "$dry_run" = true ]; then
        print_message info "${MUTED}[dry-run] would write development wrapper to ${NC}${INSTALL_DIR}/opencode"
        health_wrapper="warn"
        health_add warn "Wrapper" "Skipped due to --dry-run"
    else
        cat > "${INSTALL_DIR}/opencode" <<WRAPPER
#!/usr/bin/env bash
# OpenCode local development wrapper
REPO_ROOT="$REPO_ROOT"
$ui_export

# Check if we are in development mode
if [ -f "\$REPO_ROOT/packages/opencode/src/index.ts" ]; then
    cd "\$REPO_ROOT"
    exec bun run --cwd packages/opencode --conditions=browser src/index.ts "\$@"
else
    echo "Error: Development files not found"
    exit 1
fi
WRAPPER
        chmod 755 "${INSTALL_DIR}/opencode"
        health_wrapper="pass"
        health_add pass "Wrapper" "${INSTALL_DIR}/opencode"
        print_message info "${MUTED}Created development wrapper${NC}"
    fi

    if [ "$dry_run" != true ] && ! cmp -s "$lock_backup" "$REPO_ROOT/bun.lock"; then
        cp "$lock_backup" "$REPO_ROOT/bun.lock"
        record_action "restore-bun-lock"
        print_message warning "${ORANGE}Restore:${NC} bun.lock restored to pre-install snapshot"
    fi

    capture_snapshot "$snapshot_post" "$REPO_ROOT" "$shell_config_file"
    local cmp_result
    cmp_result=$(compare_snapshots)
    compare_status=$(printf "%s" "$cmp_result" | sed -n '1p')
    compare_summary=$(printf "%s" "$cmp_result" | sed -n '2p')
    if [ "$compare_status" = "fail" ]; then
        fail_local "Post-install environment comparison detected regressions"
    fi

    specific_version="local"
    print_message info "${MUTED}Local install completed successfully!${NC}"
}

if [ "$local_repo" = true ]; then
    install_from_local_repo
elif [ -n "$binary_path" ]; then
    install_from_binary
else
    check_version
    if [ "$dry_run" = true ]; then
        print_message info "${MUTED}[dry-run] would download and install ${NC}$specific_version"
    else
        download_and_install
    fi
fi


add_to_path() {
    local config_file=$1
    local command=$2

    if grep -Fxq "$command" "$config_file"; then
        print_message info "Command already exists in $config_file, skipping write."
    elif [[ -w $config_file ]]; then
        echo -e "\n# opencode" >> "$config_file"
        echo "$command" >> "$config_file"
        print_message info "${MUTED}Successfully added ${NC}opencode ${MUTED}to \$PATH in ${NC}$config_file"
    else
        print_message warning "Manually add the directory to $config_file (or similar):"
        print_message info "  $command"
    fi
}

if [ -z "$current_shell" ]; then
    current_shell=$(shell_detect)
fi

if [[ "$no_modify_path" != "true" ]]; then
    config_file=$(pick_shell_config "$current_shell")
    if [[ -z $config_file ]]; then
        health_shell="warn"
        health_add warn "Shell config" "No writable config found for $current_shell"
        print_message warning "No config file found for $current_shell. You may need to manually add to PATH:"
        print_message info "  export PATH=$INSTALL_DIR:\$PATH"
        shell_config_file="(manual)"
    else
        write_block "$config_file" "opencode managed" "$(managed_block "$current_shell")"
        if [ "$dry_run" != true ]; then
            export PATH=$INSTALL_DIR:$PATH
        fi
        shell_config_file="$config_file"
        health_shell="pass"
        health_add pass "Shell config" "$config_file"
    fi

    if [[ "$local_ui" = true ]]; then
        ui_path="$REPO_ROOT/packages/app/dist"
        if [[ -n $config_file ]]; then
            write_block "$config_file" "opencode ui managed" "$(managed_ui_block "$current_shell" "$ui_path")"
            if [ "$dry_run" != true ]; then
                export OPENCODE_UI_DIR="$ui_path"
            fi
            print_message info "${MUTED}Managed ${NC}OPENCODE_UI_DIR ${MUTED}in ${NC}$config_file"
            health_ui_dir="pass"
            health_add pass "OPENCODE_UI_DIR" "$config_file"
        else
            health_ui_dir="warn"
            health_add warn "OPENCODE_UI_DIR" "No shell config file to update automatically"
        fi
    fi
else
    health_shell="warn"
    health_add warn "Shell config" "Skipped due to --no-modify-path"
    if [ "$local_ui" = true ]; then
        health_ui_dir="warn"
        health_add warn "OPENCODE_UI_DIR" "Skipped due to --no-modify-path"
    fi
fi

if [ -n "${GITHUB_ACTIONS-}" ] && [ "${GITHUB_ACTIONS}" == "true" ]; then
    echo "$INSTALL_DIR" >> $GITHUB_PATH
    print_message info "Added $INSTALL_DIR to \$GITHUB_PATH"
fi

if [ "$local_repo" != true ] && [ ! -f "$snapshot_pre" ]; then
    capture_snapshot "$snapshot_post" "$PWD" "$shell_config_file"
fi

if [ -f "$snapshot_pre" ] && [ -f "$snapshot_post" ] && [ -z "$compare_summary" ]; then
    cmp_result=$(compare_snapshots)
    compare_status=$(printf "%s" "$cmp_result" | sed -n '1p')
    compare_summary=$(printf "%s" "$cmp_result" | sed -n '2p')
elif [ -z "$compare_summary" ]; then
    compare_status="warn"
    compare_summary="Comparison skipped (no pre-install snapshot)"
fi

write_health_json

if [ "$local_repo" = true ]; then
    print_health
fi

print_message info "${MUTED}Install log:${NC} $run_log"
print_message info "${MUTED}Health JSON:${NC} $health_json"
if [ -f "$compare_json" ]; then
    print_message info "${MUTED}Compare JSON:${NC} $compare_json"
fi
runtime_finalize

echo -e ""
echo -e "${MUTED}                    ${NC}             ▄     "
echo -e "${MUTED}█▀▀█ █▀▀█ █▀▀█ █▀▀▄ ${NC}█▀▀▀ █▀▀█ █▀▀█ █▀▀█"
echo -e "${MUTED}█░░█ █░░█ █▀▀▀ █░░█ ${NC}█░░░ █░░█ █░░█ █▀▀▀"
echo -e "${MUTED}▀▀▀▀ █▀▀▀ ▀▀▀▀ ▀  ▀ ${NC}▀▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀▀▀▀"
echo -e ""
echo -e ""
echo -e "${MUTED}OpenCode includes free models, to start:${NC}"
echo -e ""
echo -e "cd <project>  ${MUTED}# Open directory${NC}"
echo -e "opencode      ${MUTED}# Run command${NC}"
echo -e ""
echo -e "${MUTED}For more information visit ${NC}https://opencode.ai/docs"
echo -e ""
echo -e ""
